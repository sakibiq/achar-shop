# ============================================================
# ENVIRONMENT VARIABLES - achar-shop
# ============================================================
# Copy this file and rename it to .env.local
# Then fill in your real values.

# -----------------------------------------------------------
# RESEND API KEY
# 1. Go to https://resend.com and create a free account
# 2. Go to API Keys section
# 3. Create a new API key
# 4. Paste it below (keep the quotes)
# -----------------------------------------------------------
RESEND_API_KEY=re_your_api_key_here

# -----------------------------------------------------------
# YOUR ORDER NOTIFICATION EMAIL
# This is the email where you will receive all orders.
# Change this to your own email address.
# -----------------------------------------------------------
ORDER_NOTIFICATION_EMAIL=sakibiq001@gmail.com
